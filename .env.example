# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: use a different model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Use local Ollama instead of OpenAI (no key, no quota). Install from https://ollama.com then: ollama run llama3.2:1b
# USE_OLLAMA=true
# OLLAMA_MODEL=llama3.2:1b

# Restrict which sites can embed the widget (comma-separated). Leave unset to allow all.
# WIDGET_ORIGINS=https://eswarrayavarapu.com,https://www.eswarrayavarapu.com
